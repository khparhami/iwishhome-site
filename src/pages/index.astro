---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.find(p => p.data.featured) ?? posts[0];

const services = [
  {
    icon: '🔍',
    title: 'Full Property Search',
    desc: 'We identify, evaluate, and shortlist properties — both on-market and off-market — so you only spend time on real contenders.',
  },
  {
    icon: '🏷️',
    title: 'Auction Bidding',
    desc: 'Calm, strategic bidding backed by real comparable sale data. No emotion, no overpaying.',
  },
  {
    icon: '📋',
    title: 'Property Assessment',
    desc: 'Detailed due diligence covering comparable sales, council overlays, flood maps, and building report coordination.',
  },
  {
    icon: '🤝',
    title: 'Off-Market Access',
    desc: 'Strong relationships with selling agents across Sydney give our clients early access to properties before they hit the portals.',
  },
];

const steps = [
  { num: '01', title: 'Discovery Call', desc: 'We talk through your brief — suburbs, budget, must-haves, and timeline. Completely free and no obligation.' },
  { num: '02', title: 'Active Search', desc: 'We go to work — inspecting properties, running due diligence, and filtering out anything that doesn\'t meet your brief.' },
  { num: '03', title: 'Secure & Settle', desc: 'We negotiate or bid at auction on your behalf, then coordinate through to settlement.' },
];

const stats = [
  { value: '97%', label: 'Client satisfaction' },
  { value: '$120k+', label: 'Avg. negotiated saving' },
  { value: '6 weeks', label: 'Median time to purchase' },
  { value: '200+', label: 'Properties secured' },
];
---

<BaseLayout title="I Wish Home" description="Sydney buyer's agency helping you find and secure the right property — without the stress. Expert buyer's advocacy, auction bidding, and off-market access.">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="tag">Sydney Buyer's Agency</span>
        <h1>Your Advocate in the Property Market</h1>
        <p class="hero-lead">
          The vendor's agent is fighting for the seller. Who's fighting for you?
          I Wish Home represents buyers exclusively — so you get the right property at the right price.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary">Book a Free Call</a>
          <a href="#services" class="btn btn--outline">How It Works</a>
        </div>
        <p class="hero-note">No obligation. 30-minute discovery call.</p>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-card">
          <div class="hero-card-badge">Off-Market</div>
          <div class="hero-card-suburb">Balmain, NSW</div>
          <div class="hero-card-price">Secured $85k under asking</div>
          <div class="hero-card-footer">
            <span>3 bed · 2 bath · Period terrace</span>
          </div>
        </div>
        <div class="hero-card hero-card--small">
          <div class="hero-card-badge">Auction Win</div>
          <div class="hero-card-suburb">Newtown, NSW</div>
          <div class="hero-card-price">Won on first bid</div>
          <div class="hero-card-footer">
            <span>2 bed · 1 bath · Victorian</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="trust-bar">
    <div class="container trust-inner">
      {stats.map(s => (
        <div class="trust-stat">
          <span class="trust-value">{s.value}</span>
          <span class="trust-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header">
        <span class="tag">What We Do</span>
        <h2>End-to-End Buyer Representation</h2>
        <div class="divider"></div>
        <p>From the initial brief to settlement day, we handle the complexity so you can focus on what matters.</p>
      </div>

      <div class="services-grid">
        {services.map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--alt" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <span class="tag">The Process</span>
        <h2>Simple. Transparent. Effective.</h2>
        <div class="divider"></div>
      </div>

      <div class="steps">
        {steps.map(step => (
          <div class="step">
            <div class="step-num">{step.num}</div>
            <div class="step-body">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container testimonial-wrap">
      <blockquote class="testimonial">
        <p>"We'd been searching for 14 months and kept losing at auction. Alex found us an off-market property in Northcote that ticked every box — and negotiated $70,000 below the vendor's expectations. Worth every cent."</p>
        <footer>
          <strong>Sarah &amp; Tom K.</strong>
          <span>First-home buyers, Northcote</span>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-header">
          <span class="tag">From the Blog</span>
          <h2>Property Insights for Buyers</h2>
          <div class="divider"></div>
        </div>

        <a href={`/blog/${featured.slug}`} class="featured-post card">
          <div class="featured-post-body">
            <span class="tag">{featured.data.category}</span>
            <h3>{featured.data.title}</h3>
            <p>{featured.data.description}</p>
            <span class="read-more">Read article →</span>
          </div>
        </a>

        <div style="margin-top: 2rem; text-align: center;">
          <a href="/blog" class="btn btn--outline">See All Articles</a>
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2>Ready to Stop Searching and Start Finding?</h2>
      <p>Book a free 30-minute call with Alex to talk through your property brief. No pitch, no pressure — just honest advice.</p>
      <a href="/contact" class="btn btn--light">Book Your Free Call</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, var(--color-accent) 0%, #2e1f14 100%);
    color: var(--color-bg);
    padding: 6rem 1.5rem 5rem;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content .tag {
    background: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .hero-content h1 {
    color: var(--color-bg);
    margin-bottom: 1.25rem;
  }

  .hero-lead {
    font-size: 1.15rem;
    color: rgba(250,247,242,0.82);
    line-height: 1.7;
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .hero-actions .btn--outline {
    color: var(--color-bg);
    border-color: rgba(250,247,242,0.4);
  }

  .hero-actions .btn--outline:hover {
    background: rgba(250,247,242,0.1);
    color: var(--color-bg);
  }

  .hero-note {
    font-size: 0.82rem;
    color: rgba(250,247,242,0.5);
    max-width: 100%;
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }

  .hero-card {
    background: rgba(250,247,242,0.08);
    border: 1px solid rgba(250,247,242,0.15);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    width: 280px;
    backdrop-filter: blur(8px);
  }

  .hero-card--small {
    width: 240px;
    align-self: flex-start;
    margin-left: 3rem;
  }

  .hero-card-badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .hero-card-suburb {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-bg);
    margin-bottom: 0.4rem;
  }

  .hero-card-price {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .hero-card-footer {
    font-size: 0.78rem;
    color: rgba(250,247,242,0.5);
    border-top: 1px solid rgba(250,247,242,0.1);
    padding-top: 0.75rem;
  }

  /* Trust bar */
  .trust-bar {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    text-align: center;
    padding: 2.5rem 1.5rem;
    gap: 1rem;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .trust-value {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .trust-label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* Section header */
  .section-header {
    max-width: 640px;
    margin-bottom: 3.5rem;
  }

  .section-header .tag {
    margin-bottom: 1rem;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
  }

  .service-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
  }

  .step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .step:last-child { border-bottom: none; }

  .step-num {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    padding-top: 0.1rem;
  }

  .step-body h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .step-body p {
    color: var(--color-text-muted);
    font-size: 0.97rem;
  }

  /* Testimonial */
  .testimonial-wrap {
    max-width: 760px;
  }

  .testimonial {
    background: var(--color-bg-alt);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: 2.5rem 2.5rem 2.5rem 2rem;
  }

  .testimonial p {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.65;
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: 1.5rem;
    max-width: 100%;
  }

  .testimonial footer {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .testimonial footer strong {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-accent);
  }

  .testimonial footer span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Featured post */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
  }

  .featured-post-body {
    padding: 2.5rem;
  }

  .featured-post-body .tag { margin-bottom: 1rem; }

  .featured-post-body h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .featured-post-body p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .read-more {
    font-weight: 600;
    color: var(--color-primary-dark);
    font-size: 0.92rem;
  }

  /* CTA section */
  .cta-section {
    background: linear-gradient(135deg, var(--color-accent) 0%, #2e1f14 100%);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    color: var(--color-bg);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: rgba(250,247,242,0.75);
    margin: 0 auto 2rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-visual {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .hero-card--small { margin-left: 0; }
    .trust-inner { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .hero { padding: 4rem 1.25rem 3.5rem; }
    .hero-visual { display: none; }
    .trust-inner { grid-template-columns: repeat(2, 1fr); }
    .step { grid-template-columns: 56px 1fr; gap: 1rem; }
    .testimonial { padding: 1.75rem 1.5rem; }
    .featured-post-body { padding: 1.5rem; }
  }
</style>
