---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, author, category, image, imageAlt } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article class="blog-post">
    <div class="blog-hero container">
      <div class="blog-meta">
        <span class="tag">{category}</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="author">By {author}</span>
      </div>
      <h1>{title}</h1>
      <p class="blog-lead">{description}</p>
    </div>

    {image && (
      <div class="blog-cover container">
        <img src={image} alt={imageAlt ?? title} loading="eager" />
      </div>
    )}

    <div class="blog-body container">
      <div class="prose">
        <slot />
      </div>

      <aside class="blog-sidebar">
        <div class="cta-card">
          <h3>Ready to find your home?</h3>
          <p>Book a free, no-obligation call with Alex to talk through your property search.</p>
          <a href="/contact" class="btn btn--primary">Book a Free Call</a>
        </div>
      </aside>
    </div>
  </article>

  <div class="back-to-blog container">
    <a href="/blog" class="btn btn--outline">&larr; Back to Blog</a>
  </div>
</BaseLayout>

<style>
  .blog-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    max-width: 860px;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .blog-meta time,
  .blog-meta .author {
    color: var(--color-text-muted);
  }

  .blog-hero h1 {
    margin-bottom: 1.25rem;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
  }

  .blog-lead {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 60ch;
  }

  .blog-cover {
    margin-bottom: 3rem;
  }

  .blog-cover img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .blog-body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
    padding-bottom: 4rem;
  }

  .blog-sidebar {
    position: sticky;
    top: 96px;
  }

  .cta-card {
    background: var(--color-accent);
    color: var(--color-bg);
    padding: 2rem;
    border-radius: var(--radius-lg);
  }

  .cta-card h3 {
    color: var(--color-primary);
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .cta-card p {
    color: rgba(250,247,242,0.8);
    font-size: 0.92rem;
    margin-bottom: 1.5rem;
    max-width: 100%;
  }

  .cta-card .btn {
    width: 100%;
    justify-content: center;
  }

  .back-to-blog {
    padding-bottom: 4rem;
  }

  @media (max-width: 900px) {
    .blog-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .blog-sidebar {
      position: static;
    }
  }
</style>
